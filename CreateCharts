function testSingleChartGeneration() {
  const SPREADSHEET_ID = "17WN0e84Q6dansBrMu_PE1YhF1wmWobN0oIzb22RSR8s";
  const SHEET_NAME = "";
  const SALES_CHART_FOLDER_ID = "1v7RQHU8l3AF1JTQ4J9SIBcn_10N11Yq5";
  const BLS_CHART_FOLDER_ID = "1lwlkt4vzohLCFsofIsU7kzGI0ZgAmE2q";

  const TARGET_REPORT_NAME = "Kay";

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = SHEET_NAME ? ss.getSheetByName(SHEET_NAME) : ss.getSheets()[0];
  const values = sheet.getDataRange().getDisplayValues();
  const headers = values[0];

  const reportNameIndex = headers.indexOf("Report Name");
  if (reportNameIndex === -1) {
    throw new Error('Column "Report Name" not found.');
  }

  const rowIndex = values.findIndex((r, i) => {
    if (i === 0) return false;
    return String(r[reportNameIndex] || "").trim() === TARGET_REPORT_NAME;
  });

  if (rowIndex === -1) {
    throw new Error('Could not find Report Name: "' + TARGET_REPORT_NAME + '"');
  }

  const row = values[rowIndex];
  const rowData = buildRowObject_(headers, row);

  Logger.log(JSON.stringify(rowData));

  const salesBlob = maybeBuildSalesChartBlob_(rowData, TARGET_REPORT_NAME);
  if (salesBlob) {
    const salesFile = upsertPngFile_(
      DriveApp.getFolderById(SALES_CHART_FOLDER_ID),
      safeFileName_(TARGET_REPORT_NAME) + "_sales_chart.png",
      salesBlob
    );
    Logger.log("Sales chart created: " + salesFile.getUrl());
  } else {
    Logger.log("No sales chart data found.");
  }

  const blsBlob = maybeBuildBlsChartBlob_(rowData, TARGET_REPORT_NAME);
  if (blsBlob) {
    const blsFile = upsertPngFile_(
      DriveApp.getFolderById(BLS_CHART_FOLDER_ID),
      safeFileName_(TARGET_REPORT_NAME) + "_bls_chart.png",
      blsBlob
    );
    Logger.log("BLS chart created: " + blsFile.getUrl());
  } else {
    Logger.log("No BLS chart data found.");
  }
}

function buildRowObject_(headers, row) {
  const out = {};
  headers.forEach(function(header, i) {
    out[header] = row[i];
  });
  return out;
}

function getRequiredColumnIndex_(headers, columnName) {
  const idx = headers.indexOf(columnName);
  if (idx === -1) {
    throw new Error('Required column not found: "' + columnName + '"');
  }
  return idx + 1;
}

function getOrCreateColumn_(sheet, headers, columnName) {
  const idx = headers.indexOf(columnName);
  if (idx !== -1) return idx + 1;

  const newCol = headers.length + 1;
  sheet.getRange(1, newCol).setValue(columnName);
  return newCol;
}

function parsePercentNumber_(value) {
  if (value === null || value === undefined || value === "") return null;

  const text = String(value).trim();
  if (!text) return null;
  if (/not sig/i.test(text)) return null;

  if (text.indexOf("%") !== -1) {
    const cleaned = text.replace("%", "").replace(/,/g, "").trim();
    const num = parseFloat(cleaned);
    return isNaN(num) ? null : num;
  }

  const cleaned = text.replace(/,/g, "").trim();
  const num = parseFloat(cleaned);
  return isNaN(num) ? null : num;
}

function safeFileName_(value) {
  return String(value || "")
    .replace(/[\\\/:*?"<>|#]+/g, "")
    .replace(/\s+/g, "_")
    .trim();
}

function directViewUrlFromFileId_(fileId) {
  return "https://drive.google.com/uc?export=view&id=" + fileId;
}

function shortenBlsKpiLabel_(label) {
  const normalized = String(label || "").trim().toLowerCase();

  if (normalized === "aided awareness") return "Awareness";
  if (normalized === "awareness") return "Awareness";
  if (normalized === "familiarity") return "Familiarity";
  if (normalized === "favorability") return "Favorability";
  if (normalized === "consideration") return "Consideration";
  if (normalized === "purchase intent") return "Intent";

  return label;
}

function round1_(value) {
  return Math.round(value * 10) / 10;
}

function normalizeConfidence_(value) {
  const text = String(value || "").trim().toLowerCase();

  if (!text) return "";
  if (text.indexOf("95") !== -1) return "95%";
  if (text.indexOf("90") !== -1) return "90%";
  if (text.indexOf("80") !== -1) return "80%";
  if (text.indexOf("not sig") !== -1) return "Not Sig";

  return String(value || "").trim();
}

function formatLiftBubbleLabel_(lift) {
  const sign = lift > 0 ? "+" : "";
  return sign + lift.toFixed(1);
}

function getLiftBubbleColor_(lift, confRaw) {
  const conf = normalizeConfidence_(confRaw);

  if (lift < 0) return "#F4A3A3";
  if (lift === 0) return "#9E9E9E";

  if (conf === "95%") return "#2E7D32";
  if (conf === "90%") return "#66BB6A";
  if (conf === "80%") return "#A5D6A7";

  return "#9E9E9E";
}
