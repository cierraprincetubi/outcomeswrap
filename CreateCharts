function maybeBuildBlsChartBlob_(rowData, reportName) {
  const labels = [];
  const controlValues = [];
  const exposedValues = [];
  const annotations = {};

  for (let i = 1; i <= 5; i++) {
    const kpi = String(rowData["BLS KPI " + i] || "").trim();
    const control = parsePercentNumber_(rowData["KPI " + i + " Control"]);
    const exposed = parsePercentNumber_(rowData["KPI " + i + " Treated"]);
    const confRaw = String(rowData["KPI " + i + " Conf"] || "").trim();

    if (!kpi || control === null || exposed === null) continue;

    const lift = round1_(exposed - control);
    const label = shortenBlsKpiLabel_(kpi);
    const bubbleColor = getLiftBubbleColor_(lift, confRaw);
    const sign = lift > 0 ? "+" : "";

    labels.push(label);
    controlValues.push(control);
    exposedValues.push(exposed);

    annotations["bubble_" + i] = {
      type: "label",
      xValue: label,
      yValue: exposed + 2,
      backgroundColor: bubbleColor,
      content: [sign + lift.toFixed(1)],
      color: "#FFFFFF",
      font: {
        size: 10,
        weight: "bold"
      },
      padding: 6,
      borderRadius: 999
    };
  }

  Logger.log(JSON.stringify({
    reportName: reportName,
    blsLabels: labels,
    blsControlValues: controlValues,
    blsExposedValues: exposedValues,
    annotations: annotations
  }));

  if (!labels.length) return null;

  const chartConfig = {
    type: "bar",
    data: {
      labels: labels,
      datasets: [
        {
          label: "Control",
          data: controlValues,
          backgroundColor: "#BDBDBD",
          borderRadius: 5,
          borderSkipped: false,
          barThickness: 24
        },
        {
          label: "Exposed",
          data: exposedValues,
          backgroundColor: "#FFDE21",
          borderRadius: 5,
          borderSkipped: false,
          barThickness: 24
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      layout: {
        padding: { top: 60, right: 20, bottom: 10, left: 10 }
      },
      plugins: {
        legend: {
          position: "top",
          align: "end",
          labels: {
            color: "#FFFFFF",
            font: { size: 11 },
            boxWidth: 14
          }
        },
        title: {
          display: true,
          text: reportName + " Brand Lift",
          color: "#FFFFFF",
          font: { size: 20, weight: "bold" },
          padding: { bottom: 16 }
        },
        annotation: {
          annotations: annotations
        }
      },
      scales: {
        x: {
