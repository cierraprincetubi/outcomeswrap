            color: "#FFFFFF",
            font: { size: 11 },
            maxRotation: 0,
            minRotation: 0
          },
          grid: { display: false },
          border: { display: false }
        },
        y: {
          beginAtZero: true,
          ticks: {
            color: "#FFFFFF",
            font: { size: 11 },
            callback: function(value) {
              return value + "%";
            }
          },
          grid: {
            color: "rgba(255,255,255,0.12)",
            drawBorder: false
          },
          border: { display: false }
        }
      }
    }
  };

  return fetchQuickChartPng_(
    chartConfig,
    safeFileName_(reportName) + "_bls_chart.png",
    1200,
    700
  );
}

function fetchQuickChartPng_(chartConfig, filename, width, height) {
  const payload = {
    width: width,
    height: height,
    format: "png",
    backgroundColor: "transparent",
    devicePixelRatio: 2,
    version: "4",
    chart: chartConfig
  };

  const response = UrlFetchApp.fetch("https://quickchart.io/chart", {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const code = response.getResponseCode();
  if (code !== 200) {
    throw new Error("QuickChart error " + code + ": " + response.getContentText());
  }

  return response.getBlob().setName(filename);
}

function upsertPngFile_(folder, filename, blob) {
  const existing = folder.getFilesByName(filename);
  while (existing.hasNext()) {
    existing.next().setTrashed(true);
  }
  blob.setName(filename);
  return folder.createFile(blob);
}

