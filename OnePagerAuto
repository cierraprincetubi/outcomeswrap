const SHEET_ID = '17WN0e84Q6dansBrMu_PE1YhF1wmWobN0oIzb22RSR8s';
const OUTPUT_FOLDER_ID = '15ORq5gq8XJgX6z_oATzFh36rA1IbbpuP';
const TEMPLATE_DOC_ID = '1dA07SL6d3fQKf6E6cMkhGRiwAWoWZRpHtAc_6xKXxe4';

function runOnePagerGeneration() {
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const sheet = ss.getSheets()[0];
  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  const urlColIndex = headers.indexOf('One-Pager URL');

  if (urlColIndex === -1) {
    throw new Error('Missing required column: One-Pager URL');
  }

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const r = mapRow_(headers, row);

    if (!isRowValid_(r)) continue;

    const existingUrl = row[urlColIndex];
    if (existingUrl && isValidDocUrl_(existingUrl)) continue;

    const yearFolder = findOrCreateYearFolder_(r['Year']);
    const docUrl = buildOnePagerFromTemplate_(r, yearFolder);

    sheet.getRange(i + 1, urlColIndex + 1).setValue(docUrl);
  }
}

function buildOnePagerFromTemplate_(r, folder) {
  const fileName = buildOutputFileName_(r);
  const templateFile = DriveApp.getFileById(TEMPLATE_DOC_ID);
  const copiedFile = templateFile.makeCopy(fileName, folder);
  const doc = DocumentApp.openById(copiedFile.getId());

  const body = doc.getBody();
  const header = doc.getHeader();
  const footer = doc.getFooter();

  const replacements = buildReplacementMap_(r);

  replaceAllText_(body, replacements);

  if (header) {
    replaceAllText_(header, replacements);
  }

  if (footer) {
    replaceAllText_(footer, replacements);
  }

  processOptionalSectionByMarkers_(body, 'BRAND', hasBrandData_(r));
  processOptionalSectionByMarkers_(body, 'CONVERSION', hasConversionData_(r));
  processOptionalSectionByMarkers_(body, 'SALES', hasSalesData_(r));
  processOptionalSectionByMarkers_(body, 'VISITATION', hasVisitationData_(r));

  insertImageAtPlaceholder_(body, '{{BLS CHART}}', r['BLS Chart URL']);
  insertImageAtPlaceholder_(body, '{{SALES CHART}}', r['Sales Chart URL']);

  cleanupUnusedPlaceholders_(body);

  if (header) {
    cleanupUnusedPlaceholders_(header);
  }

  if (footer) {
    cleanupUnusedPlaceholders_(footer);
  }

  doc.saveAndClose();
  return doc.getUrl();
}

function buildReplacementMap_(r) {
  return {
    '{{ADVERTISER}}': safeString_(r['Advertiser']),
    '{{QUARTER}}': safeString_(r['Quarter']),
    '{{YEAR}}': safeString_(r['Year']),
    '{{BLS Summary}}': buildBLSSummary_(r),

    '{{CAMPAIGN NAME}}': safeString_(r['Campaign Name']),
    '{{Campaign Start}}': formatDateIfNeeded_(r['Campaign Start Date']),
    '{{Campaign End}}': formatDateIfNeeded_(r['Campaign End Date']),

    '{{Account Manager}}': safeString_(r['Account Manager']),
    '{{Account Executive}}': safeString_(r['Account Executive']),

    '{{Spend}}': formatCurrency_(r['Spend']),
    '{{Impressions}}': formatNumber_(r['Imps']),
    '{{Reach}}': formatNumber_(r['Reach']),
    '{{Weekly Frequency}}': formatOneDecimal_(r['Weekly Frequency']),

    '{{CVR Type}}': safeString_(r['CVR Type']),
    '{{CVR Type 2}}': safeString_(r['CVR Type 2']),
    '{{CVR Type 3}}': safeString_(r['CVR Type 3']),
    '{{CVR Lift}}': formatLiftWithConf_(r['CVR Lift'], r['CVR Lift Conf']),
    '{{CVR Lift 2}}': formatLiftWithConf_(r['CVR Lift 2'], r['CVR Lift Conf 2']),
    '{{CVR Lift 3}}': formatLiftWithConf_(r['CVR Lift 3'], r['CVR Lift Conf 3']),
    '{{CVR Conf}}': '',
    '{{CVR 2 Conf}}': '',
    '{{CVR 3 Conf}}': '',

    '{{Sales Type}}': safeString_(r['Sales Type']),
    '{{Sales Lift}}': formatLiftWithConf_(r['Sales Lift'], r['Sales Lift Conf']),
    '{{IROAS}}': formatIROAS_(r['IROAS']),

    '{{Visit Lift %}}': formatPercent_(r['Visit Lift %']),
    '{{Incremental Visits}}': formatNumber_(r['Incremental Visits']),
    '{{CPIV}}': formatCurrency_(r['CPIV']),

    '{{BLS CHART}}': '{{BLS CHART}}',
    '{{SALES CHART}}': '{{SALES CHART}}'
  };
}

function buildBLSSummary_(r) {
  const items = [];

  addBLSSummaryLine_(items, r['BLS KPI 1'], r['BLS KPI 1 Abs Lift']);
  addBLSSummaryLine_(items, r['BLS KPI 2'], r['BLS KPI 2 Abs Lift']);
  addBLSSummaryLine_(items, r['BLS KPI 3'], r['BLS KPI 3 Abs Lift']);
  addBLSSummaryLine_(items, r['BLS KPI 4'], r['BLS KPI 4 Abs Lift']);
  addBLSSummaryLine_(items, r['BLS KPI 5'], r['BLS KPI 5 Abs Lift']);

  return items.join('\n');
}

function addBLSSummaryLine_(items, kpi, lift) {
  if (!hasValue_(kpi) || !hasValue_(lift)) return;
  items.push(safeString_(kpi) + ': ' + formatPercent_(lift));
}

function processOptionalSectionByMarkers_(body, sectionName, keepSection) {
  const startMarker = '{{#' + sectionName + '}}';
  const endMarker = '{{/' + sectionName + '}}';

  const numChildren = body.getNumChildren();
  let startIndex = -1;
  let endIndex = -1;

  for (let i = 0; i < numChildren; i++) {
    const child = body.getChild(i);
    const text = getElementText_(child).trim();

    if (text === startMarker) {
      startIndex = i;
    }

    if (text === endMarker && startIndex !== -1) {
      endIndex = i;
      break;
    }
  }

  if (startIndex === -1 || endIndex === -1) return;

  if (keepSection) {
    body.removeChild(body.getChild(endIndex));
    body.removeChild(body.getChild(startIndex));
  } else {
    for (let i = endIndex; i >= startIndex; i--) {
      body.removeChild(body.getChild(i));
    }
  }
}

function getElementText_(element) {
  const type = element.getType();

  if (type === DocumentApp.ElementType.PARAGRAPH) {
    return element.asParagraph().getText();
  }

  if (type === DocumentApp.ElementType.TABLE) {
    return element.asTable().getText();
  }

  if (type === DocumentApp.ElementType.LIST_ITEM) {
    return element.asListItem().getText();
  }

  return '';
}

function insertImageAtPlaceholder_(container, placeholder, url) {
  const found = container.findText(escapeRegex_(placeholder));
  if (!found) return;

  const paragraph = getParentParagraph_(found.getElement());
  if (!paragraph) return;

  if (!url) {
    paragraph.removeFromParent();
    return;
  }

  try {
    const blob = getDriveImageBlobFromUrl_(url);
    if (!blob) {
      paragraph.removeFromParent();
      return;
    }

    const parent = paragraph.getParent();
    const index = parent.getChildIndex(paragraph);
    paragraph.removeFromParent();

    const newParagraph = parent.insertParagraph(index, '');
    newParagraph.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
    const image = newParagraph.appendInlineImage(blob);
    fitImageToWidth_(image, 520);
  } catch (e) {
    Logger.log('Failed inserting image for ' + placeholder + ': ' + e);
    paragraph.removeFromParent();
  }
}

function cleanupUnusedPlaceholders_(container) {
  container.replaceText('\\{\\{#[^}]+\\}\\}', '');
  container.replaceText('\\{\\{/[^}]+\\}\\}', '');
  container.replaceText('\\{\\{[^}]+\\}\\}', '');
}

function replaceAllText_(container, replacements) {
  Object.keys(replacements).forEach(function(key) {
    container.replaceText(escapeRegex_(key), replacements[key]);
  });
}

function hasConversionData_(r) {
  return hasValue_(r['CVR Type']) ||
    hasValue_(r['CVR Lift']) ||
    hasValue_(r['CVR Type 2']) ||
    hasValue_(r['CVR Lift 2']) ||
    hasValue_(r['CVR Type 3']) ||
    hasValue_(r['CVR Lift 3']);
}

function hasSalesData_(r) {
  return hasValue_(r['Sales Type']) ||
    hasValue_(r['Sales Lift']) ||
    hasValue_(r['IROAS']) ||
    hasValue_(r['Sales Chart URL']);
}

function hasBrandData_(r) {
  return hasValue_(r['BLS Chart URL']) ||
    hasValue_(r['BLS KPI 1']) ||
    hasValue_(r['BLS KPI 1 Abs Lift']) ||
    hasValue_(r['BLS KPI 2']) ||
    hasValue_(r['BLS KPI 2 Abs Lift']) ||
    hasValue_(r['BLS KPI 3']) ||
    hasValue_(r['BLS KPI 3 Abs Lift']) ||
    hasValue_(r['BLS KPI 4']) ||
    hasValue_(r['BLS KPI 4 Abs Lift']) ||
    hasValue_(r['BLS KPI 5']) ||
    hasValue_(r['BLS KPI 5 Abs Lift']);
}

function hasVisitationData_(r) {
  return hasValue_(r['Visit Lift %']) ||
    hasValue_(r['Incremental Visits']) ||
    hasValue_(r['CPIV']);
}

function getDriveImageBlobFromUrl_(url) {
  const fileId = extractDriveFileId_(url);
  if (!fileId) return null;
  return DriveApp.getFileById(fileId).getBlob();
}

function extractDriveFileId_(url) {
  if (!url) return null;

  const patterns = [
    /\/d\/([-\w]{25,})/,
    /id=([-\w]{25,})/,
    /[-\w]{25,}/
  ];

  for (let i = 0; i < patterns.length; i++) {
    const match = url.match(patterns[i]);
    if (match) return match[1] || match[0];
  }
  return null;
}

function fitImageToWidth_(image, maxWidth) {
  const width = image.getWidth();
  const height = image.getHeight();

  if (width > maxWidth) {
    const ratio = maxWidth / width;
    image.setWidth(maxWidth);
    image.setHeight(Math.round(height * ratio));
  }
}

function getParentParagraph_(element) {
  let current = element;
  while (current && current.getType() !== DocumentApp.ElementType.PARAGRAPH) {
    current = current.getParent();
  }
  return current;
}

function buildOutputFileName_(r) {
  return [
    safeFileNamePart_(r['Quarter']),
    safeFileNamePart_(r['Year']),
    safeFileNamePart_(r['Advertiser']),
    safeFileNamePart_(r['Campaign Name']),
    'Doc'
  ].join('_');
}

function safeFileNamePart_(value) {
  return safeString_(value).replace(/[\\\/:*?"<>|#]+/g, '').trim();
}

function formatDateIfNeeded_(value) {
  if (!value) return '';
  if (Object.prototype.toString.call(value) === '[object Date]' && !isNaN(value.getTime())) {
    return Utilities.formatDate(value, Session.getScriptTimeZone(), 'M/d/yyyy');
  }
  return String(value).trim();
}

function formatCurrency_(value) {
  if (value === null || value === undefined || value === '') return '';
  const num = parseNumeric_(value);
  if (num === null) return String(value).trim();
  return '$' + Math.round(num).toLocaleString();
}

function formatNumber_(value) {
  if (value === null || value === undefined || value === '') return '';
  const num = parseNumeric_(value);
  if (num === null) return String(value).trim();
  return Math.round(num).toLocaleString();
}

function formatOneDecimal_(value) {
  if (value === null || value === undefined || value === '') return '';
  const num = parseNumeric_(value);
  if (num === null) return String(value).trim();
  return num.toFixed(1);
}

function formatPercent_(value) {
  if (value === null || value === undefined || value === '') return '';
  const num = parseNumeric_(value);
  if (num === null) return String(value).trim();

  let pct = num;
  if (pct > 0 && pct <= 1) pct = pct * 100;

  return pct.toFixed(1) + '%';
}

function formatLiftWithConf_(lift, conf) {
  const liftStr = formatPercent_(lift);
  if (!liftStr) return '';

  const confStr = formatConfidence_(conf);
  return confStr ? liftStr + ' (' + confStr + ')' : liftStr;
}

function formatIROAS_(value) {
  if (value === null || value === undefined || value === '') return '';
  const num = parseNumeric_(value);
  if (num === null) return String(value).trim();
  return num.toFixed(1) + 'x';
}

function formatConfidence_(value) {
  if (value === null || value === undefined || value === '') return '';
  const str = String(value).trim();
  if (!str) return '';

  if (/not sig/i.test(str)) return 'Not Sig';
  if (/%$/.test(str)) return str;

  const num = parseNumeric_(str);
  if (num === null) return str;

  let pct = num;
  if (pct > 0 && pct <= 1) pct = pct * 100;

  return pct.toFixed(0) + '%';
}

function parseNumeric_(value) {
  if (typeof value === 'number') return value;

  const cleaned = String(value)
    .replace(/[$,%xX,\s]/g, '')
    .trim();

  if (cleaned === '') return null;

  const num = Number(cleaned);
  return isNaN(num) ? null : num;
}

function safeString_(value) {
  if (value === null || value === undefined) return '';
  return String(value).trim();
}

function hasValue_(value) {
  return safeString_(value) !== '';
}

function mapRow_(headers, row) {
  const obj = {};
  headers.forEach(function(header, i) {
    obj[header] = row[i];
  });
  return obj;
}

function isRowValid_(r) {
  return hasValue_(r['Advertiser']) &&
    hasValue_(r['Campaign Name']) &&
    hasValue_(r['Quarter']) &&
    hasValue_(r['Year']);
}

function isValidDocUrl_(url) {
  try {
    const id = extractDriveFileId_(url);
    if (!id) return false;
    DriveApp.getFileById(id);
    return true;
  } catch (e) {
    return false;
  }
}

function findOrCreateYearFolder_(year) {
  const parent = DriveApp.getFolderById(OUTPUT_FOLDER_ID);
  const folders = parent.getFoldersByName(String(year));
  return folders.hasNext() ? folders.next() : parent.createFolder(String(year));
}

function escapeRegex_(text) {
  return text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}
