function getFrequencyNarrative(weeklyFrequency, resultsAreWeak) {
  if (isNaN(weeklyFrequency) || weeklyFrequency < 0) {
    return {
      summaryNote: "",
      recommendation: ""
    };
  }

  if (weeklyFrequency < 0.5) {
    return {
      summaryNote: "Weekly frequency was light, suggesting there may be room to improve message retention and campaign impact through more consistent exposure.",
      recommendation: "Increase weekly frequency in future campaigns to strengthen message retention and improve the likelihood of driving measurable response."
    };
  }

  if (weeklyFrequency >= 0.5 && weeklyFrequency < 0.8) {
    return {
      summaryNote: "Weekly frequency was relatively light, leaving potential headroom to build stronger repetition if greater impact is desired.",
      recommendation: "Consider testing a higher weekly frequency to determine whether additional exposure can improve campaign performance without sacrificing efficiency."
    };
  }

  if (weeklyFrequency >= 0.8 && weeklyFrequency <= 1.3) {
    return {
      summaryNote: "Weekly frequency was in a healthy range, supporting consistent exposure without indicating immediate frequency concerns.",
      recommendation: ""
    };
  }

  if (weeklyFrequency > 1.3) {
    if (resultsAreWeak) {
      return {
        summaryNote: "Weekly frequency was elevated relative to results, suggesting the campaign may have approached or exceeded an efficient exposure level.",
        recommendation: "Be mindful of possible overexposure in future campaigns and test a more balanced weekly frequency to improve efficiency if performance remains soft."
      };
    }

    return {
      summaryNote: "",
      recommendation: ""
    };
  }

  return {
    summaryNote: "",
    recommendation: ""
  };
}

function isWeakResults(input) {
  const conversionLiftValue = input.topConversion && input.topConversion.lift ? numericValue(input.topConversion.lift) : null;
  const salesLiftValue = input.topSales && input.topSales.lift ? numericValue(input.topSales.lift) : null;
  const brandLiftValue = input.topBrand && input.topBrand.lift ? numericValue(input.topBrand.lift) : null;
  const visitLiftValue = input.visitLift ? numericValue(input.visitLift) : null;
  const iroasValue = input.iroas ? numericValue(input.iroas) : null;

  const positiveSignals = [];

  if (conversionLiftValue !== null) positiveSignals.push(conversionLiftValue >= 1.0);
  if (salesLiftValue !== null) positiveSignals.push(salesLiftValue >= 1.0);
  if (brandLiftValue !== null) positiveSignals.push(brandLiftValue >= 1.0);
  if (visitLiftValue !== null) positiveSignals.push(visitLiftValue >= 1.0);
  if (iroasValue !== null) positiveSignals.push(iroasValue >= 1.0);

  if (positiveSignals.length === 0) {
    return false;
  }

  const positives = positiveSignals.filter(function(v) {
    return v;
  }).length;

  return positives === 0;
}

function getStrongestBrandMetric(metrics) {
  if (!metrics || metrics.length === 0) return null;

  let best = metrics[0];
  let bestValue = numericValue(metrics[0].lift);

  for (let i = 1; i < metrics.length; i++) {
    const currentValue = numericValue(metrics[i].lift);
    if (currentValue > bestValue) {
      best = metrics[i];
      bestValue = currentValue;
    }
  }

  return best;
}

function numericValue(value) {
  const raw = String(value || "").replace(/[^0-9.\-]/g, "");
  const num = Number(raw);
  return isNaN(num) ? -999999 : num;
}

function advertiserOrFallback(advertiser) {
  return advertiser && String(advertiser).trim() !== "" ? advertiser : "the advertiser";
}

function normalizeLabel(label, fallback) {
  const clean = String(label || "").trim();
  return clean !== "" ? clean : fallback;
}

function normalizePluralLabel(label, fallback) {
  const clean = String(label || "").trim();
  if (clean === "") return fallback;
  return clean.toLowerCase();
}

function compact(values) {
  const result = [];
  for (let i = 0; i < values.length; i++) {
    const v = String(values[i] || "").trim();
    if (v !== "") result.push(v);
  }
  return result;
}

function countTrue(values) {
  let count = 0;
  for (let i = 0; i < values.length; i++) {
    if (values[i]) count++;
  }
  return count;
}

function joinWithAnd(items) {
  if (!items || items.length === 0) return "";
  if (items.length === 1) return items[0];
  if (items.length === 2) return items[0] + " and " + items[1];
  return items.slice(0, -1).join(", ") + ", and " + items[items.length - 1];
}

function firstNonEmpty(values) {
  for (let i = 0; i < values.length; i++) {
    const v = String(values[i] || "").trim();
    if (v !== "") return v;
  }
  return "";
}

function formatPercent(value) {
  const cleaned = cleanNumeric(value);
  if (cleaned === "") return "";
  return cleaned + "%";
}

function formatCurrency(value) {
  const cleaned = cleanNumeric(value);
  if (cleaned === "") return "";
  return "$" + cleaned;
}

function formatNumber(value) {
  return cleanNumeric(value);
}

function cleanNumeric(value) {
  const raw = String(value || "").trim();
  if (raw === "") return "";

  const numeric = raw.replace(/[^0-9.\-]/g, "");
  if (numeric === "" || isNaN(Number(numeric))) return "";

  return Number(numeric).toFixed(1).replace(/\.0$/, "");
}
