function createWrapReportsForAllRows() {
  const SPREADSHEET_ID = "17WN0e84Q6dansBrMu_PE1YhF1wmWobN0oIzb22RSR8s";
  const TEMPLATE_ID = "1lmWSQJbZtMHf4M_m0S0GmJik1ba4ovZJRXwuixO6ktk";
  const OUTPUT_FOLDER_ID = "1cleKvIbzlBwJDqoJI1lCkrN7hOl00kuD";
  const BLS_PLACEHOLDER = "{{BLS_CHART}}";
  const SALES_LIFT_PLACEHOLDER = "{{SALES_LIFT_CHART}}";

  const spreadsheet = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = spreadsheet.getSheets()[0];
  const folder = DriveApp.getFolderById(OUTPUT_FOLDER_ID);

  ensureLeadingColumns(sheet, ["Quarter", "Season", "Year"]);

  let data = sheet.getDataRange().getDisplayValues();
  let headers = data[0];

  getOrCreateColumn(sheet, headers, "Deck URL");
  getOrCreateColumn(sheet, headers, "Generated At");

  data = sheet.getDataRange().getDisplayValues();
  headers = data[0];

  const quarterCol = headers.indexOf("Quarter") + 1;
  const seasonCol = headers.indexOf("Season") + 1;
  const yearCol = headers.indexOf("Year") + 1;
  const deckUrlColUpdated = headers.indexOf("Deck URL") + 1;
  const generatedAtColUpdated = headers.indexOf("Generated At") + 1;

  if (data.length < 2) {
    Logger.log("No campaign rows found.");
    return;
  }

  for (let r = 1; r < data.length; r++) {
    const row = data[r];

    if (row.join("").trim() === "") continue;

    const rowData = {};
    headers.forEach((header, i) => {
      rowData[header] = row[i];
    });

    const campaignName = String(rowData["Campaign Name"] || "").trim();
    const existingDeckUrl = String(rowData["Deck URL"] || "").trim();
    const reportName = rowData["Report Name"] || ("Wrap Report " + r);

    if (campaignName === "") {
      Logger.log("Skipped row " + (r + 1) + ": Campaign Name is blank.");
      continue;
    }

    if (existingDeckUrl !== "") {
      Logger.log("Skipped existing report for row " + (r + 1) + ": " + reportName);
      continue;
    }

    try {
      const copy = DriveApp.getFileById(TEMPLATE_ID).makeCopy(
        reportName + " - Wrap Report",
        folder
      );

      const presentation = SlidesApp.openById(copy.getId());
      const generatedAt = new Date();

      sheet.getRange(r + 1, generatedAtColUpdated).setValue(generatedAt);

      const campaignStartDate = parseSheetDate(rowData["Campaign Start Date"]);
      if (!campaignStartDate) {
        throw new Error('Invalid or blank "Campaign Start Date" for row ' + (r + 1));
      }

      const fiscal = getFiscalAttributes(campaignStartDate);
      sheet.getRange(r + 1, quarterCol).setValue(fiscal.quarter);
      sheet.getRange(r + 1, seasonCol).setValue(fiscal.season);
      sheet.getRange(r + 1, yearCol).setValue(fiscal.year);

      const deckUrl = presentation.getUrl();
      sheet.getRange(r + 1, deckUrlColUpdated).setValue(deckUrl);

      SpreadsheetApp.flush();

      const refreshedHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];
      const refreshedRow = sheet.getRange(r + 1, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];

      const refreshedRowData = {};
      refreshedHeaders.forEach((header, i) => {
        refreshedRowData[header] = refreshedRow[i];
      });

      const narrative = buildNarrative(refreshedRowData);
      refreshedRowData["Insight"] = narrative.summary;
      refreshedRowData["Recommendations"] = narrative.recommendations;

      refreshedHeaders.forEach((header) => {
        presentation.replaceAllText("{{" + header + "}}", refreshedRowData[header] || "");
      });

      presentation.replaceAllText("{{Insight}}", refreshedRowData["Insight"] || "");
      presentation.replaceAllText("{{Recommendations}}", refreshedRowData["Recommendations"] || "");

      const blsChartValue = String(refreshedRowData["BLS Chart"] || "").trim();
      if (blsChartValue !== "") {
        try {
          const fileId = extractDriveFileId(blsChartValue);
          replacePlaceholderWithDriveImage(presentation, BLS_PLACEHOLDER, fileId);
          Logger.log("Inserted BLS chart for row " + (r + 1) + ": " + reportName);
        } catch (imageError) {
          Logger.log("Failed to insert BLS chart for row " + (r + 1) + " (" + reportName + "): " + imageError.message);
        }
      } else {
        Logger.log("No BLS Chart value for row " + (r + 1) + ": " + reportName);
      }

      const salesLiftChartValue = String(refreshedRowData["Sales Lift Chart"] || "").trim();
