    } catch (e) {
      Logger.log("ERROR on row " + (r + 1) + " (" + reportName + "): " + e.message);
    }
  }
}

function replacePlaceholderWithDriveImage(presentation, placeholderText, fileId) {
  const file = DriveApp.getFileById(fileId);
  const mimeType = file.getMimeType();

  if (!mimeType.startsWith("image/")) {
    throw new Error("Chart file is not an image. Mime type: " + mimeType);
  }

  const imageBlob = file.getBlob();
  const slides = presentation.getSlides();
  let found = false;

  for (let i = 0; i < slides.length; i++) {
    const slide = slides[i];
    const result = findPlaceholderElement(slide.getPageElements(), placeholderText);

    if (result) {
      const element = result.element;
      const left = element.getLeft();
      const top = element.getTop();
      const width = element.getWidth();
      const height = element.getHeight();

      slide.insertImage(imageBlob, left, top, width, height);
      element.remove();

      Logger.log("Inserted image into slide " + (i + 1));
      found = true;
      break;
    }
  }

  if (!found) {
    throw new Error(
      'Placeholder ' + placeholderText + ' not found. Put a normal text box on the slide itself containing exactly ' + placeholderText
    );
  }
}

function findPlaceholderElement(pageElements, placeholderText) {
  for (let i = 0; i < pageElements.length; i++) {
    const element = pageElements[i];
    const type = element.getPageElementType();

    if (type === SlidesApp.PageElementType.SHAPE) {
      try {
        const text = element.asShape().getText().asString().trim();
        if (normalizePlaceholder(text) === normalizePlaceholder(placeholderText)) {
          return { element: element };
        }
      } catch (e) {}
    }

    if (type === SlidesApp.PageElementType.GROUP) {
      try {
        const children = element.asGroup().getChildren();
        const result = findPlaceholderElement(children, placeholderText);
        if (result) return result;
      } catch (e) {}
    }
  }

  return null;
}

function normalizePlaceholder(text) {
  return String(text || "")
    .replace(/\s+/g, "")
    .trim();
}

function extractDriveFileId(value) {
  value = String(value || "").trim();

  if (!value.includes("http")) {
    return value;
  }

  let match = value.match(/\/file\/d\/([-\w]{25,})/);
  if (match) return match[1];

  match = value.match(/[?&]id=([-\w]{25,})/);
  if (match) return match[1];

  match = value.match(/[-\w]{25,}/);
  if (match) return match[0];

  throw new Error("Could not extract Drive file ID from: " + value);
}

function getOrCreateColumn(sheet, headers, columnName) {
  const existingIndex = headers.indexOf(columnName);
  if (existingIndex !== -1) {
    return existingIndex + 1;
  }

  const newCol = headers.length + 1;
  sheet.getRange(1, newCol).setValue(columnName);
  return newCol;
}

function ensureLeadingColumns(sheet, desiredHeaders) {
  const currentHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];

  for (let i = desiredHeaders.length - 1; i >= 0; i--) {
    if (currentHeaders[i] !== desiredHeaders[i]) {
      sheet.insertColumnBefore(1);
    }
  }

  for (let i = 0; i < desiredHeaders.length; i++) {
    sheet.getRange(1, i + 1).setValue(desiredHeaders[i]);
  }
}

function parseSheetDate(value) {
  if (!value) return null;

  if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value.getTime())) {
    return value;
  }

  const parsed = new Date(value);
  if (!isNaN(parsed.getTime())) {
    return parsed;
  }

  return null;
}

function getFiscalAttributes(date) {
  const month = date.getMonth() + 1;
  const year = date.getFullYear();

  let quarter = "";
  let season = "";

  if (month >= 1 && month <= 3) {
    quarter = "Q1";
  } else if (month >= 4 && month <= 6) {
    quarter = "Q2";
  } else if (month >= 7 && month <= 9) {
    quarter = "Q3";
  } else {
    quarter = "Q4";
  }

  if (month === 12 || month === 1 || month === 2) {
    season = "Winter";
  } else if (month >= 3 && month <= 5) {
    season = "Spring";
  } else if (month >= 6 && month <= 8) {
    season = "Summer";
  } else {
    season = "Fall";
  }

  return {
    quarter: quarter,
    season: season,
    year: year
  };
}

